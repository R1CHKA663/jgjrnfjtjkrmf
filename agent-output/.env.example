# Casino Backend — Environment Variables
# Copy to .env and fill in real values

# ── Database ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=casino_db
DB_USER=casino_user
DB_PASS=your_strong_password_here

# ── App ───────────────────────────────────────────
APP_ENV=production
APP_URL=https://yourcasino.com
APP_SECRET=change_me_to_64_random_chars_here

# ── JWT ───────────────────────────────────────────
JWT_SECRET=another_very_long_random_secret_key
JWT_TTL=86400

# ── Email (SMTP) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourcasino.com
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=Casino

# ── RTP Settings ─────────────────────────────────
RTP_CHECK_INTERVAL=100    # Re-evaluate RTP bias every N bets
RTP_CORRECTION_STRENGTH=0.3  # 0.0 = no correction, 1.0 = full correction
